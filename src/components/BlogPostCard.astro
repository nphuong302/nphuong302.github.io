---
interface Props {
  title: string;
  brief: string;
  url: string;
  publishedAt: string;
  coverImage?: { url: string } | null;
  tags?: { name: string }[];
  delay?: number;
}

const { title, brief, url, publishedAt, coverImage, tags = [], delay = 0 } = Astro.props;

const date = new Date(publishedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<a
  href={url}
  target="_blank"
  class="bg-rose-bg2 border border-rose-bg3 rounded-2xl overflow-hidden hover:-translate-y-1.5 hover:shadow-xl hover:border-rose-primary transition-all duration-300 flex flex-col group"
  data-aos="fade-up"
  data-aos-delay={delay}
>
  {coverImage?.url && (
    <div class="h-44 overflow-hidden">
      <img src={coverImage.url} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    </div>
  )}
  <div class="p-5 flex flex-col gap-3 flex-1">
    <h3 class="font-bold text-rose-fg text-sm leading-snug group-hover:text-rose-primary transition-colors line-clamp-2">{title}</h3>
    <p class="text-rose-muted text-xs leading-relaxed line-clamp-3">{brief}</p>
    <div class="mt-auto flex items-center justify-between pt-2">
      <span class="text-xs text-rose-muted">{date}</span>
      {tags.length > 0 && (
        <div class="flex gap-1 flex-wrap justify-end">
          {tags.slice(0, 2).map(tag => (
            <span class="bg-rose-bg3/60 text-rose-highlight text-xs px-2 py-0.5 rounded-full">{tag.name}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</a>
