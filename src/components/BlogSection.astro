---
import BlogPostCard from './BlogPostCard.astro';

const GQL = 'https://gql.hashnode.com';
const query = `
  query GetPosts($username: String!) {
    user(username: $username) {
      publications(first: 1) {
        edges {
          node {
            posts(first: 5) {
              edges {
                node {
                  title brief url publishedAt
                  coverImage { url }
                  tags { name }
                }
              }
            }
          }
        }
      }
    }
  }
`;

let posts: any[] = [];
try {
  const res = await fetch(GQL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ query, variables: { username: 'nphuong302' } }),
  });
  const json = await res.json();
  const edges = json?.data?.user?.publications?.edges?.[0]?.node?.posts?.edges ?? [];
  posts = edges.map((e: any) => e.node);
} catch {
  posts = [];
}
---

<section id="writing" class="py-24 bg-rose-bg1/40">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16" data-aos="fade-down">
      <h2 class="text-4xl font-bold text-rose-fg mb-3">Research & Writing</h2>
      <p class="text-rose-muted text-lg">
        Paper breakdowns, experiment logs, and technical decisions documented openly
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {posts.map((post, i) => (
          <BlogPostCard {...post} delay={i * 100} />
        ))}
      </div>
    ) : (
      <!-- No posts yet: show the "coming soon" card + pipeline -->
      <div class="grid md:grid-cols-2 gap-8">

        <div class="bg-rose-bg2 border border-rose-bg3 rounded-2xl p-8 flex gap-6" data-aos="fade-right">
          <div class="w-14 h-14 rounded-full bg-rose-bg1 border border-rose-bg3 flex items-center justify-center text-rose-primary text-2xl flex-shrink-0">
            <i class="fa-brands fa-hashnode"></i>
          </div>
          <div>
            <h3 class="font-bold text-rose-fg mb-2">Hashnode Blog</h3>
            <p class="text-rose-muted text-sm leading-relaxed mb-3">
              Where I write about ML research — paper breakdowns, experiment analysis,
              model design trade-offs, and lessons learned from real implementations.
              The GitHub repos hold the code; Hashnode holds the thinking behind it.
            </p>
            <p class="text-rose-muted text-xs mb-4">
              <i class="fas fa-circle-dot text-rose-primary mr-1"></i>
              Posts in progress — first articles coming soon.
            </p>
            <a
              href="https://hashnode.com/@nphuong302"
              target="_blank"
              class="inline-flex items-center gap-2 bg-rose-bg1 border border-rose-bg3 text-rose-secondary px-4 py-2 rounded-full text-sm font-medium hover:bg-rose-bg3 hover:-translate-y-0.5 transition-all duration-200"
            >
              <i class="fa-brands fa-hashnode"></i> Visit Blog
            </a>
          </div>
        </div>

        <div class="bg-rose-bg2 border border-rose-bg3 rounded-2xl p-8" data-aos="fade-left">
          <h3 class="font-bold text-rose-fg mb-6">How the pipeline works</h3>
          <ul class="space-y-4 list-none p-0 m-0">
            <li class="flex gap-4 items-start">
              <span class="text-rose-primary text-lg w-6 flex-shrink-0"><i class="fa-brands fa-hashnode"></i></span>
              <div>
                <div class="font-semibold text-rose-fg text-sm">Hashnode</div>
                <div class="text-rose-muted text-xs">Research notes, paper breakdowns, experiment analysis, lessons learned</div>
              </div>
            </li>
            <li class="flex gap-4 items-start">
              <span class="text-rose-primary text-lg w-6 flex-shrink-0"><i class="fab fa-github"></i></span>
              <div>
                <div class="font-semibold text-rose-fg text-sm">GitHub</div>
                <div class="text-rose-muted text-xs">Code, READMEs, reproducible pipelines, repo links</div>
              </div>
            </li>
            <li class="flex gap-4 items-start">
              <span class="text-rose-primary text-lg w-6 flex-shrink-0"><i class="fas fa-globe"></i></span>
              <div>
                <div class="font-semibold text-rose-fg text-sm">This site</div>
                <div class="text-rose-muted text-xs">Aggregates both — one place to see the full picture</div>
              </div>
            </li>
          </ul>
        </div>

      </div>
    )}

    <div class="text-center mt-8" data-aos="fade-up">
      <a
        href="https://hashnode.com/@nphuong302"
        target="_blank"
        class="inline-flex items-center gap-2 border border-rose-primary text-rose-primary px-6 py-3 rounded-full text-sm font-medium hover:bg-rose-primary hover:text-white hover:-translate-y-0.5 transition-all duration-200"
      >
        <i class="fa-brands fa-hashnode"></i> Read on Hashnode
      </a>
    </div>

  </div>
</section>
