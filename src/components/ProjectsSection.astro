---
import projects from '../data/projects.json';
import ProjectCard from './ProjectCard.astro';

const featured = projects.filter(p => p.featured);
---

<section id="projects" class="py-24 bg-rose-bg0">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16" data-aos="fade-down">
      <h2 class="text-4xl font-bold text-rose-fg mb-3">Featured Projects</h2>
      <p class="text-rose-muted text-lg">Practical applications of ML, AI, and data analysis</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {featured.map((project, i) => (
        <ProjectCard {...project} delay={i * 100} />
      ))}
    </div>

    <div class="text-center" data-aos="fade-up">
      <a
        href="/projects"
        class="inline-flex items-center gap-2 bg-gradient-to-br from-rose-primary to-rose-highlight text-white px-8 py-4 rounded-full font-semibold hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
      >
        <i class="fas fa-code"></i> View All Projects
      </a>
    </div>

  </div>
</section>
