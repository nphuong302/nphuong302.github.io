---
import skills from '../data/skills.json';
---

<section id="skills" class="py-24 bg-rose-bg1/40">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16" data-aos="fade-down">
      <h2 class="text-4xl font-bold text-rose-fg mb-3">Technical Expertise</h2>
      <p class="text-rose-muted text-lg">Tools, frameworks, and systems I work with</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {skills.map((skill, i) => (
        <div
          class="bg-rose-bg2 border border-rose-bg3 rounded-2xl p-6 hover:-translate-y-2 hover:shadow-lg hover:border-rose-primary transition-all duration-300"
          data-aos="fade-up"
          data-aos-delay={i * 100}
        >
          <h3 class="text-rose-secondary font-semibold mb-4 flex items-center gap-2">
            <i class={skill.icon}></i> {skill.title}
          </h3>
          <div class="flex flex-wrap gap-2">
            {skill.tags.map(tag => (
              <span class="bg-rose-bg3/60 text-rose-highlight text-xs px-2.5 py-1 rounded-full font-medium">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
