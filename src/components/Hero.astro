---
interface Props {
  variant?: 'home' | 'projects';
}
const { variant = 'home' } = Astro.props;
---

<section class="min-h-screen flex flex-col items-center justify-center text-center px-6 bg-gradient-to-b from-rose-bg0 to-rose-bg1 relative pt-16">
  <div class="max-w-3xl">

    {variant === 'home' ? (
      <>
        <h1 class="text-5xl md:text-6xl font-bold text-rose-fg mb-4">
          Phương Nguyễn
        </h1>
        <h2 class="text-2xl md:text-3xl text-rose-primary font-medium mb-6">
          <span id="typing-text" class="typing-cursor pr-1">Machine Learning Developer</span>
        </h2>
        <p class="text-rose-muted text-lg mb-10 leading-relaxed">
          Building models with <strong class="text-rose-fg">Python, PyTorch, and OpenCV</strong><br />
          Computer Vision · RAG Systems · Data Analysis
        </p>

        <div class="flex justify-center gap-12 mb-10">
          <div class="text-center">
            <div class="text-3xl font-bold text-rose-primary">9+</div>
            <div class="text-sm text-rose-muted mt-1">Projects</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-rose-primary">2+</div>
            <div class="text-sm text-rose-muted mt-1">Years Industry</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-rose-primary">3</div>
            <div class="text-sm text-rose-muted mt-1">Domains</div>
          </div>
        </div>

        <a href="#about" class="inline-flex items-center gap-2 bg-gradient-to-br from-rose-primary to-rose-highlight text-white px-8 py-4 rounded-full font-semibold hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <i class="fas fa-user"></i> Explore My Journey
        </a>
      </>
    ) : (
      <>
        <h1 class="text-5xl md:text-6xl font-bold text-rose-fg mb-6">
          Projects Portfolio
        </h1>
        <p class="text-rose-muted text-xl mb-10">
          Practical projects at the intersection of
          <span class="text-rose-primary font-semibold"> Data</span>,
          <span class="text-rose-secondary font-semibold"> Machine Learning</span>, and
          <span class="text-rose-highlight font-semibold"> AI Systems</span>
        </p>
        <a href="#projects" class="inline-flex items-center gap-2 bg-gradient-to-br from-rose-primary to-rose-highlight text-white px-8 py-4 rounded-full font-semibold hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <i class="fas fa-rocket"></i> Explore Projects
        </a>
      </>
    )}
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-rose-primary animate-bounce">
    <i class="fas fa-chevron-down"></i>
  </div>
</section>

{variant === 'home' && (
  <script>
    const roles = ["Machine Learning Developer", "Software Engineer"];
    let idx = 0, char = 0, deleting = false;
    function type() {
      const el = document.getElementById("typing-text");
      if (!el) return;
      const text = roles[idx];
      el.textContent = deleting ? text.slice(0, --char) : text.slice(0, ++char);
      if (!deleting && char === text.length) setTimeout(() => { deleting = true; }, 1500);
      if (deleting && char === 0) { deleting = false; idx = (idx + 1) % roles.length; }
      setTimeout(type, deleting ? 50 : 100);
    }
    document.addEventListener("DOMContentLoaded", () => setTimeout(type, 800));
  </script>
)}
